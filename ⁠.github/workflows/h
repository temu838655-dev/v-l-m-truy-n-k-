name: Tu Dong Xuat APK Vo Lam

on:
  push:
    branches: [ "*" ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - name: Lay code ve may ao
      uses: actions/checkout@v4

    - name: Dong goi HTML thanh APK
      uses: ayodelesegun/html-to-apk-action@v1.1
      with:
        app-name: "Vo Lam Mini"
        package-name: "com.volam.mini2026"
        icon-path: ""

    - name: Luu file APK de tai ve
      uses: actions/upload-artifact@v4
      with:
        name: VoLamAPK
        path: app-release.apk
